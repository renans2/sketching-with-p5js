---
import fs from "node:fs";
import path from "node:path";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const sketchesDir = path.resolve("./public/sketches");
  const files = fs.readdirSync(sketchesDir);

  return files.map((file: any) => {
    const slug = file.replace(".js", "");

    return {
      params: { slug },
    };
  });
}

const { slug } = Astro.params;
const sketchSrc = `/sketches/${slug}.js`;
---

<Layout>
  <main class="space-y-5">
    <div>
      <p class="text-3xl text-center mt-6">Sketch title here</p>
      <ul class="text-xl justify-center flex gap-4">
        <li>Tag 1</li>
        <li>Tag 2</li>
        <li>Tag 3</li>
      </ul>
    </div>
    <div id="canvas-container" class="flex justify-center"></div>
    <p class="text-xl text-center">Sketch quote is going to be here</p>
  </main>
</Layout>

<script src=`${sketchSrc}` is:inline></script>
